# Relayer wallet private key — must have ETH to pay gas
# For local anvil use any of the 10 funded test keys, e.g. account[1] (NOT account[0] which is the deployer)
# For Sepolia use a real wallet with Sepolia ETH (get from https://sepoliafaucet.com)
RELAYER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Chain ID — 31337 for local anvil, 11155111 for Sepolia
CHAIN_ID=31337

# RPC endpoint
# Anvil:   http://127.0.0.1:8545
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>
RPC_URL=http://127.0.0.1:8545

# AnonymousVoting contract address
CONTRACT_ADDRESS=0x610178dA211FEF7D417bC0e6FeD39F05609AD788

# Port the relayer listens on
PORT=3001

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:3000
